#!/bin/sh
commit_msg=$(cat "$1")
pattern="^(feat|fix|ui|refactor|chore|docs|test|perf)(\([a-z0-9\-]+\))?: .{1,100}$"

RED='\033[0;31m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
GRAY='\033[0;90m'
BOLD='\033[1m'
RESET='\033[0m'

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  printf "\n"
  printf "${RED}${BOLD}  ✖ Commit message không đúng format!${RESET}\n"
  printf "\n"
  printf "${GRAY}  Message của bạn:${RESET} ${YELLOW}%s${RESET}\n" "$commit_msg"
  printf "\n"
  printf "${BOLD}  Format:${RESET} ${CYAN}<type>(<scope>): <description>${RESET}\n"
  printf "${BOLD}  Ví dụ: ${RESET} ${CYAN}feat(song): add song upload feature${RESET}\n"
  printf "\n"
  printf "${BOLD}  Types: ${RESET}${GRAY}feat | fix | ui | refactor | chore | docs | test | perf${RESET}\n"
  printf "${BOLD}  Scopes:${RESET}${GRAY} auth | song | playlist | artist | stream | frontend | backend | api${RESET}\n"
  printf "\n"
  exit 1
fi
